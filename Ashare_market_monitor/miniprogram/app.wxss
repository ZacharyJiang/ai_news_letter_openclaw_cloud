page {
  background: #f8fafc;
  color: #0f172a;
  font-size: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.label {
  color: #64748b;
}

.value {
  font-weight: 600;
}

.up {
  color: #d92d20;
}

.down {
  color: #0b8f55;
}
