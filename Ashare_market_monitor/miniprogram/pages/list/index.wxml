<view class="page">
  <view class="card panel">
    <view class="row">
      <text class="label">关键词(代码/名称)</text>
      <input class="input" placeholder="如 510300 / 沪深300" value="{{query.keyword}}" bindinput="onKeywordInput" />
    </view>

    <view class="grid2">
      <view class="field">
        <text class="label">规模最小(亿)</text>
        <input class="input" type="digit" data-field="min_scale" value="{{query.min_scale}}" bindinput="onNumericInput" />
      </view>
      <view class="field">
        <text class="label">规模最大(亿)</text>
        <input class="input" type="digit" data-field="max_scale" value="{{query.max_scale}}" bindinput="onNumericInput" />
      </view>

      <view class="field">
        <text class="label">现价最小</text>
        <input class="input" type="digit" data-field="min_price" value="{{query.min_price}}" bindinput="onNumericInput" />
      </view>
      <view class="field">
        <text class="label">现价最大</text>
        <input class="input" type="digit" data-field="max_price" value="{{query.max_price}}" bindinput="onNumericInput" />
      </view>

      <view class="field">
        <text class="label">总费率最小(%)</text>
        <input class="input" type="digit" data-field="min_fee" value="{{query.min_fee}}" bindinput="onNumericInput" />
      </view>
      <view class="field">
        <text class="label">总费率最大(%)</text>
        <input class="input" type="digit" data-field="max_fee" value="{{query.max_fee}}" bindinput="onNumericInput" />
      </view>

      <view class="field">
        <text class="label">幅度最小(%)</text>
        <input class="input" type="digit" data-field="min_distance" value="{{query.min_distance}}" bindinput="onNumericInput" />
      </view>
      <view class="field">
        <text class="label">幅度最大(%)</text>
        <input class="input" type="digit" data-field="max_distance" value="{{query.max_distance}}" bindinput="onNumericInput" />
      </view>
    </view>

    <view class="row controls">
      <picker mode="selector" range="{{distanceModeOptions}}" range-key="label" value="{{distanceModeIndex}}" bindchange="onDistanceModeChange">
        <view class="picker">幅度口径: {{distanceModeOptions[distanceModeIndex].label}}</view>
      </picker>

      <picker mode="selector" range="{{sortOptions}}" range-key="label" value="{{sortIndex}}" bindchange="onSortChange">
        <view class="picker">排序字段: {{sortOptions[sortIndex].label}}</view>
      </picker>
    </view>

    <view class="row controls">
      <button size="mini" bindtap="toggleOrder">排序: {{query.order === 'desc' ? '降序' : '升序'}}</button>
      <button size="mini" type="primary" bindtap="applyFilter">应用筛选</button>
      <button size="mini" bindtap="resetFilter">重置</button>
    </view>

    <view class="row switch-row">
      <text class="label">自动刷新(10秒)</text>
      <switch checked="{{autoRefresh}}" bindchange="toggleAutoRefresh" />
    </view>
  </view>

  <view class="summary">
    <text>总数: {{total}} | 当前页: {{page}} | 更新时间: {{lastFetchAt || '-'}} </text>
  </view>

  <view wx:if="{{syncStatus.running}}" class="sync-tip">
    元数据同步中: {{syncStatus.processed || 0}} / {{syncStatus.total || 0}}
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <block wx:for="{{items}}" wx:key="code">
    <view class="card item" bindtap="goDetail" data-code="{{item.code}}" data-name="{{item.name}}">
      <view class="head">
        <text class="name">{{item.name}}</text>
        <text class="code">{{item.code}}</text>
      </view>
      <view class="grid3">
        <view>
          <text class="label">现价</text>
          <text class="value">{{item.price === null || item.price === undefined ? '--' : item.price}}</text>
        </view>
        <view>
          <text class="label">规模(亿)</text>
          <text class="value">{{item.fund_scale_billion === null || item.fund_scale_billion === undefined ? '--' : item.fund_scale_billion}}</text>
        </view>
        <view>
          <text class="label">总费率%</text>
          <text class="value">{{item.total_fee_pct === null || item.total_fee_pct === undefined ? '--' : item.total_fee_pct}}</text>
        </view>
        <view>
          <text class="label">离历史最高跌幅%</text>
          <text class="value down">{{item.drawdown_from_ath_pct === null || item.drawdown_from_ath_pct === undefined ? '--' : item.drawdown_from_ath_pct}}</text>
        </view>
        <view>
          <text class="label">离历史最低涨幅%</text>
          <text class="value up">{{item.rebound_from_atl_pct === null || item.rebound_from_atl_pct === undefined ? '--' : item.rebound_from_atl_pct}}</text>
        </view>
        <view>
          <text class="label">管理+托管+销售%</text>
          <text class="value">{{item.management_fee_pct === null || item.management_fee_pct === undefined ? 0 : item.management_fee_pct}} + {{item.custody_fee_pct === null || item.custody_fee_pct === undefined ? 0 : item.custody_fee_pct}} + {{item.sales_fee_pct === null || item.sales_fee_pct === undefined ? 0 : item.sales_fee_pct}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="pager">
    <button size="mini" bindtap="goPrev">上一页</button>
    <button size="mini" bindtap="goNext">下一页</button>
  </view>
</view>
