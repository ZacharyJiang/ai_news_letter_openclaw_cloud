<view class="page">
  <view class="card header">
    <view class="title-row">
      <text class="name">{{name || code}}</text>
      <text class="code">{{code}}</text>
    </view>

    <view class="period-row">
      <picker mode="selector" range="{{periodOptions}}" range-key="label" value="{{periodIndex}}" bindchange="onPeriodChange">
        <view class="period-picker">周期: {{periodOptions[periodIndex].label}}</view>
      </picker>
      <text wx:if="{{loading}}" class="loading">加载中...</text>
    </view>

    <view class="stats">
      <view>
        <text class="label">历史最高</text>
        <text class="value">{{stats.ath === null || stats.ath === undefined ? '--' : stats.ath}}</text>
      </view>
      <view>
        <text class="label">历史最低</text>
        <text class="value">{{stats.atl === null || stats.atl === undefined ? '--' : stats.atl}}</text>
      </view>
      <view>
        <text class="label">离历史最高跌幅%</text>
        <text class="value down">{{stats.drawdown_from_ath_pct === null || stats.drawdown_from_ath_pct === undefined ? '--' : stats.drawdown_from_ath_pct}}</text>
      </view>
      <view>
        <text class="label">离历史最低涨幅%</text>
        <text class="value up">{{stats.rebound_from_atl_pct === null || stats.rebound_from_atl_pct === undefined ? '--' : stats.rebound_from_atl_pct}}</text>
      </view>
    </view>
  </view>

  <view class="card chart-card">
    <canvas
      canvas-id="klineCanvas"
      id="klineCanvas"
      width="{{canvasWidth}}"
      height="{{canvasHeight}}"
      style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
    ></canvas>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
