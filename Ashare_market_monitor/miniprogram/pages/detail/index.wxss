.page {
  padding: 12rpx;
}

.header {
  margin-bottom: 14rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
}

.code {
  color: #64748b;
}

.period-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.period-picker {
  border: 1rpx solid #d9e2ef;
  border-radius: 10rpx;
  background: #f8fafc;
  padding: 10rpx 12rpx;
}

.loading {
  color: #64748b;
}

.stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}

.label {
  color: #64748b;
  display: block;
  font-size: 24rpx;
}

.value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 4rpx;
}

.up {
  color: #d92d20;
}

.down {
  color: #0b8f55;
}

.chart-card {
  overflow: hidden;
}

.error {
  margin-top: 10rpx;
  color: #d92d20;
}
